# Configuración Global de Persistencia (MongoDB)
MONGO_URI=mongodb://mongo-primary:27017,mongo-sec1:27017,mongo-sec2:27017/?replicaSet=rs0
DB_NAME=streaming_db

# Rutas de Seguridad Criptográfica (Tokens JWT)
PRIVATE_KEY_PATH=/secrets/private.pem
PUBLIC_KEY_PATH=/secrets/public.pem

# Almacenamiento de Video On Demand (VOD)
MEDIA_DIR=/media

# Configuración del Ingestion Worker
TARGET_FRAME=250